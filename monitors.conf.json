{
  "_说明": [
    "在此文件中配置你要监控的代码仓库列表。配置后无需重启 CC 即可生效。",
    "添加/删除仓库直接编辑此文件即可，无需 MCP 工具。",
    "",
    "必填字段: name, url, repoType, module, branch",
    "",
    "repoType: frontend → 克隆到 Repository/Frontend repository/",
    "          backend  → 克隆到 Repository/Backend repository/",
    "module:   业务模块名（如 \"用户中心\"、\"订单系统\"），用于 repo_monitor 和 repo_clone 的批量操作",
    "",
    "platform: github  = GitHub REST API v3",
    "          local   = 本机 git 命令（需 localPath）",
    "          generic = 通用 REST API / CodeHub / GitLab（需 genericConfig.apiBase + apiTemplate）",
    "",
    "API 模板占位符: {owner} {repo} {branch} {projectId}",
    "MR 查询需要配置 genericConfig.mrApiTemplate（用于 repo_monitor reset 和 repo_clone incremental）",
    "",
    "══════════════════════════════════════════════════",
    "baseDir 说明（可选）:",
    "  所有代码克隆的存储根目录。路径规则: {baseDir}/Repository/{Frontend|Backend} repository/{repo-name}/{branch|mr-id}",
    "  - 本地 MCP（stdio）: MCP Server 直接在 baseDir 下执行 git clone",
    "  - 远程 MCP（HTTP）: 客户端在自己的机器上配置 baseDir，clone 后的代码落在客户端本地",
    "  - 不配置则默认使用 MCP Server 项目自身的目录（向后兼容）",
    "  示例: \"D:/MyWorkspace\" 或 \"/home/user/projects\""
  ],

  "baseDir": "D:/0_WayneArchiveFiles/MCP-Servers/Test-Impact-Analysis-mcp",

  "repositories": [
    {
      "name": "gh-backend",
      "url": "git@github.com:myteam/backend.git",
      "platform": "github",
      "branch": "main",
      "repoType": "backend",
      "module": "示例模块"
    },
    {
      "name": "gh-frontend",
      "url": "git@github.com:myteam/frontend.git",
      "platform": "github",
      "branch": "main",
      "repoType": "frontend",
      "module": "示例模块"
    },

    {
      "name": "codehub-order-service",
      "url": "git@codehub.huawei.com:myproject/order-service.git",
      "platform": "generic",
      "branch": "develop",
      "repoType": "backend",
      "module": "订单系统",
      "genericConfig": {
        "apiBase": "https://codehub.huawei.com",
        "apiTemplate": "/api/v1/projects/{owner}/repos/{repo}/commits?ref={branch}",
        "mrApiTemplate": "/api/v1/projects/{owner}/repos/{repo}/merge_requests?state=merged&target_branch={branch}&order_by=created_at&sort=asc"
      }
    },
    {
      "name": "codehub-payment-service",
      "url": "git@codehub.huawei.com:myproject/payment-service.git",
      "platform": "generic",
      "branch": "develop",
      "repoType": "backend",
      "module": "支付系统",
      "genericConfig": {
        "apiBase": "https://codehub.huawei.com",
        "apiTemplate": "/api/v1/projects/{owner}/repos/{repo}/commits?ref={branch}",
        "mrApiTemplate": "/api/v1/projects/{owner}/repos/{repo}/merge_requests?state=merged&target_branch={branch}&order_by=created_at&sort=asc"
      }
    },
    {
      "name": "hermes-agent-evolution",
      "url": "git@github.com:WayneLiu519888/Hermes-Agent-EvolutionV3.git",
      "platform": "github",
      "branch": "main",
      "repoType": "backend",
      "module": "Agent进化"
    },
    {
      "name": "codehub-gateway",
      "url": "git@codehub.huawei.com:myproject/api-gateway.git",
      "platform": "generic",
      "branch": "master",
      "repoType": "backend",
      "module": "网关",
      "genericConfig": {
        "apiBase": "https://codehub.huawei.com",
        "apiTemplate": "/api/v1/projects/{owner}/repos/{repo}/commits?ref={branch}"
      }
    }
  ]
}
